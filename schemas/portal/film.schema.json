{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thirdi.net/schemas/portal/film.schema.json",
  "title": "Film creative block",
  "description": "Film-specific presentation nested inside a project: ideas, scenes, script, and approvals. Media may be absent; scenes exist before any still/video.",
  "$defs": {
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "time", "description", "status", "mediaState"],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/id" },
        "title": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
        "time": { "type": "string" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "direction": { "type": "string" },
        "transition": { "type": "string" },
        "purpose": { "type": "string" },
        "status": { "type": "string" },
        "script": { "type": "string" },
        "mediaState": { "$ref": "common.schema.json#/$defs/mediaState" },
        "assetIds": { "type": "array", "items": { "type": "string" } },
        "comment": { "$ref": "common.schema.json#/$defs/commentTarget" }
      }
    },
    "idea": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "slug", "title", "concept", "status", "scenes"],
      "properties": {
        "number": { "type": "string" },
        "slug": { "$ref": "common.schema.json#/$defs/slug" },
        "title": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
        "concept": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
        "status": { "type": "string" },
        "recommended": { "type": "boolean" },
        "runtime": { "type": "string" },
        "sceneCount": { "type": "integer", "minimum": 0 },
        "demoState": { "type": "string" },
        "approval": { "type": "string" },
        "strength": { "type": "string" },
        "complexity": { "type": "string" },
        "distinctiveness": { "type": "string" },
        "recommendation": { "type": "string" },
        "scenes": { "type": "array", "items": { "$ref": "film.schema.json#/$defs/scene" } }
      }
    },
    "filmBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coreMessage", "script", "scriptSource", "ideas"],
      "properties": {
        "coreMessage": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
        "creativeThesis": { "type": "string" },
        "script": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
        "scriptSource": { "$ref": "common.schema.json#/$defs/source" },
        "comparisonCriteria": { "type": "array", "items": { "type": "string" } },
        "recommendation": { "type": "string" },
        "approvals": { "type": "array", "items": { "type": "string" } },
        "ideas": { "type": "array", "minItems": 1, "items": { "$ref": "film.schema.json#/$defs/idea" } }
      }
    }
  }
}
