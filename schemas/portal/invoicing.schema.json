{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thirdi.net/schemas/portal/invoicing.schema.json",
  "title": "Value & Results",
  "description": "Client-visible value, effort, and results data. Shows the Third i-client relationship compounding value over time: increasing value, decreasing time, continued hard work. Reusable across clients — supports completed projects with dollar amounts and in-progress projects with relative value.",
  "type": "object",
  "required": ["schemaVersion", "tenant", "clientSafe", "asOf", "metrics", "narrative", "efficiencyModel", "learningPrivacy", "futureValueSections", "source"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0.0" },
    "tenant": { "$ref": "common.schema.json#/$defs/tenant" },
    "clientSafe": { "type": "boolean", "const": true },
    "asOf": { "$ref": "common.schema.json#/$defs/isoDate" },
    "metrics": {
      "type": "object",
      "description": "Momentum metrics showing the current state of the relationship.",
      "required": ["projectsActive", "deliverablesCompleted", "hoursInvested", "capabilitiesDelivered"],
      "properties": {
        "projectsActive": {
          "type": "object",
          "required": ["count", "label"],
          "properties": {
            "count": { "type": "integer", "minimum": 0 },
            "descriptor": { "type": "string", "description": "Short label next to the number (e.g., 'film')." },
            "label": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "Plain-English description (e.g., '1 film in production')." }
          }
        },
        "deliverablesCompleted": {
          "type": "object",
          "required": ["count", "label"],
          "properties": {
            "count": { "type": "integer", "minimum": 0 },
            "descriptor": { "type": "string", "description": "Short label next to the number, normally 'deliverables'." },
            "label": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "Plain-English description of what's been delivered." }
          }
        },
        "hoursInvested": {
          "type": "object",
          "required": ["hours", "label"],
          "properties": {
            "hours": { "type": "number", "minimum": 0, "description": "Total Third i hours in the relationship." },
            "descriptor": { "type": "string", "description": "Short label next to the number, normally 'hours'." },
            "label": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "Plain-English context (e.g., '20 hours on Film 1 Final Demo')." }
          }
        },
        "capabilitiesDelivered": {
          "type": "object",
          "required": ["count", "label"],
          "properties": {
            "count": { "type": "integer", "minimum": 0 },
            "descriptor": { "type": "string", "description": "Short label next to the number, normally 'capabilities'." },
            "label": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "Plain-English description of available capabilities." }
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "description": "Capabilities Third i has delivered — tools built, knowledge transferred, and services enabled.",
      "items": {
        "type": "object",
        "required": ["title", "type", "description"],
        "properties": {
          "title": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
          "type": { "type": "string", "enum": ["tool", "knowledge", "service"], "description": "tool = something built and handed over; knowledge = expertise the client now has access to; service = ongoing service now available." },
          "description": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
          "status": { "type": "string", "enum": ["delivered", "available", "planned"], "description": "delivered = done; available = ready to use; planned = coming soon." }
        }
      }
    },
    "narrative": {
      "type": "object",
      "description": "The value narrative — how the relationship compounds value over time.",
      "required": ["summary", "faster", "smarter", "expanding"],
      "properties": {
        "summary": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "One-paragraph summary of the Third i-client value story." },
        "faster": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "How Third i delivers more value in less time as the workflow learns." },
        "smarter": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "How Third i's understanding deepens each project." },
        "expanding": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "How Third i takes on more of the client's work over time." }
      }
    },
    "completedProjects": {
      "type": "array",
      "description": "Completed projects with real dollar amounts and effort data. Empty for clients with no completed projects yet (e.g., bkWatch). Populated for clients with completed work (e.g., Shaw).",
      "items": {
        "type": "object",
        "required": ["title", "completedAt", "hours", "amount", "outcome"],
        "properties": {
          "title": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
          "completedAt": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "Client-visible completion date or approved period label." },
          "hours": { "type": "number", "minimum": 0, "description": "Actual project hours." },
          "amount": { "type": "string", "description": "Dollar amount (e.g., '$5,000'). Shown only for completed projects." },
          "outcome": { "$ref": "common.schema.json#/$defs/nonEmptyText", "description": "What was delivered and the value it produced." }
        }
      }
    },
    "serviceCatalog": {
      "type": "object",
      "description": "Planned roadmap of services, shown on the AI Roadmap page. Organized into AI Implementation (subcategorized), Value Audit (free), and Partnership Extension (free). Items may be flagged 'planned' (green) or 'recommended' (yellow) by ROI.",
      "properties": {
        "aiImplementation": { "$ref": "invoicing.schema.json#/$defs/serviceCategoryWithSubcats" },
        "valueAudit": { "$ref": "invoicing.schema.json#/$defs/serviceCategory" },
        "partnershipExtension": { "$ref": "invoicing.schema.json#/$defs/serviceCategory" }
      }
    },
    "efficiencyTrend": {
      "type": "array",
      "description": "Legacy hours-per-project series. New expected-vs-actual presentation uses efficiencyModel.",
      "items": {
        "type": "object",
        "required": ["project", "hours"],
        "properties": {
          "project": { "type": "string" },
          "hours": { "type": "number" },
          "amount": { "type": "number" },
          "formattedAmount": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "efficiencyModel": {
      "type": "object",
      "description": "Tenant-owned efficiency evidence. The graph renders only after at least two completed projects; expected values stay directional and private.",
      "required": ["minCompletedProjects", "completedProjectCount", "unit", "futureLabel", "projects"],
      "properties": {
        "minCompletedProjects": { "type": "integer", "minimum": 2 },
        "completedProjectCount": { "type": "integer", "minimum": 0 },
        "unit": { "type": "string", "const": "hours per finished minute" },
        "futureLabel": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "status", "actualHoursPerMinute"],
            "properties": {
              "label": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
              "status": { "type": "string", "const": "completed" },
              "actualHoursPerMinute": { "type": "number", "exclusiveMinimum": 0 }
            }
          }
        }
      }
    },
    "learningPrivacy": {
      "type": "object",
      "description": "Explains how reusable methods improve without moving client-specific material between tenant workspaces.",
      "required": ["title", "description", "carriesForward", "staysPrivate"],
      "properties": {
        "title": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
        "description": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
        "carriesForward": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/nonEmptyText" } },
        "staysPrivate": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/nonEmptyText" } }
      }
    },
    "futureValueSections": {
      "type": "array",
      "minItems": 1,
      "description": "Inactive placeholders for evidence that becomes available as future projects complete.",
      "items": {
        "type": "object",
        "required": ["title", "description", "metrics"],
        "properties": {
          "title": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
          "icon": { "type": "string" },
          "statusLabel": { "type": "string" },
          "description": { "$ref": "common.schema.json#/$defs/nonEmptyText" },
          "metrics": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/nonEmptyText" } }
        }
      }
    },
    "financialSummary": {
      "type": "object",
      "description": "Real financial data from the spreadsheet.",
      "properties": {
        "totalBilled": { "type": "number" },
        "totalPaid": { "type": "number" },
        "outstanding": { "type": "number" },
        "totalHours": { "type": "number" },
        "billableHours": { "type": "number" },
        "partnershipHours": { "type": "number" },
        "activeProjects": { "type": "integer", "minimum": 0 },
        "completedProjects": { "type": "integer", "minimum": 0 },
        "effectiveRate": { "type": "number" },
        "formattedBilled": { "type": "string" },
        "formattedPaid": { "type": "string" },
        "formattedOutstanding": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "source": { "$ref": "common.schema.json#/$defs/source" }
  },
  "$defs": {
    "serviceCategory": {
      "type": "object",
      "required": ["title", "items"],
      "properties": {
        "title": { "type": "string" },
        "icon": { "type": "string" },
        "billing": { "type": "string", "enum": ["billable", "free", "fallback"] },
        "description": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "description"],
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "serviceCategoryWithSubcats": {
      "type": "object",
      "required": ["title", "subcategories"],
      "properties": {
        "title": { "type": "string" },
        "icon": { "type": "string" },
        "billing": { "type": "string" },
        "description": { "type": "string" },
        "subcategories": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "items"],
            "properties": {
              "title": { "type": "string" },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["title", "description"],
                  "properties": {
                    "title": { "type": "string" },
                    "description": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
