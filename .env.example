# ─────────────────────────────────────────────────────────────────────────────
# Third i portal environment template  (ENV-01)
#
# HOW TO USE
#   • Copy to `.env` for LOCAL development only:  cp .env.example .env
#   • `.env`, `.env.local`, `.env.production` are gitignored — never commit real values.
#   • Production values live ONLY as secret Netlify environment variables.
#   • Development / deploy-preview contexts MUST use their own non-production
#     secrets and datastore namespaces — never production passwords or data.
#
# GATE NOTE: media (R2), mail, and live-store variables are placeholders here for
# documentation. They are activated only after the named HITL gates
# (DATA-01 / DATA-02 / EMAIL-01). See plans/client-portal-masterplan/14-roadmap-hitl.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth (present in production today) ───────────────────────────────────────
# Salted scrypt hashes in the form: scrypt$<salt-b64url>$<hash-b64url>
# Generate with: node scripts/hash-password.mjs
BKWATCH_PORTAL_PASSWORD_HASH=
SHAW_PORTAL_PASSWORD_HASH=
OS_PORTAL_PASSWORD_HASH=
# 32-byte base64url secret for AES-256-GCM session encryption
PORTAL_SESSION_SECRET=

# ── Live operational store (Netlify Blobs) — GATED: DATA-01 ──────────────────
# Use a SEPARATE store namespace for dev/preview vs production.
PORTAL_DATA_STORE_VERSION=portal-live-v1

# ── Outbound email — GATED: EMAIL-01 ─────────────────────────────────────────
PORTAL_MAIL_PROVIDER=
PORTAL_MAIL_API_KEY=
PORTAL_MAIL_FROM=
PORTAL_OWNER_EMAIL=ceo@thirdi.net

# ── Media storage (Cloudflare R2) — GATED: DATA-02 ───────────────────────────
# Production and preview use different buckets/credentials. Never commit values.
PORTAL_MEDIA_PROVIDER=r2
PORTAL_MEDIA_R2_ACCOUNT_ID=
PORTAL_MEDIA_R2_BUCKET=
PORTAL_MEDIA_R2_ACCESS_KEY_ID=
PORTAL_MEDIA_R2_SECRET_ACCESS_KEY=
PORTAL_MEDIA_MAX_BYTES=2147483648
PORTAL_MEDIA_PART_BYTES=67108864
PORTAL_MEDIA_DOWNLOAD_TTL_SECONDS=14400
PORTAL_MEDIA_PART_TTL_SECONDS=3600
PORTAL_MEDIA_UPLOAD_SESSION_TTL_SECONDS=86400
PORTAL_MEDIA_CLIENT_UPLOAD_MAX_BYTES=
PORTAL_MEDIA_ALLOWED_ORIGINS=

# ── Local memory-mirror / sync — GATED: MEM-01 ───────────────────────────────
PORTAL_SYNC_TOKEN=
